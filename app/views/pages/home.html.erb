<div class="hero min-h-[calc(100vh-4rem)] bg-base-200">
  <div class="hero-content text-center">
    <div class="max-w-md">
      <h1 class="text-5xl font-bold">Did</h1>
      <p class="py-6">Track what you've done, reflect on what matters.</p>
      <% if user_signed_in? %>
        <p>Welcome back, <strong><%= current_user.username %></strong>!</p>
      <% else %>
        <div class="flex gap-4 justify-center">
          <%= link_to "Get Started", new_user_registration_path, class: "btn btn-primary" %>
          <%= link_to "Sign In", new_user_session_path, class: "btn btn-ghost" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
