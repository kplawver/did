<nav class="flex items-center justify-center gap-2 p-3 bg-base-200" data-controller="week-nav">
  <% prev_week = @week_start - 7.days %>
  <% next_week = @week_start + 7.days %>

  <% if prev_week >= current_user.created_at.to_date.beginning_of_week(:monday) %>
    <%= link_to journal_path(prev_week), class: "btn btn-ghost btn-sm" do %>
      &larr;
    <% end %>
  <% else %>
    <span class="btn btn-ghost btn-sm btn-disabled">&larr;</span>
  <% end %>

  <div class="flex gap-1">
    <% @week_dates.each do |day| %>
      <% if day > Date.current %>
        <span class="btn btn-ghost btn-sm btn-disabled opacity-30">
          <span class="hidden sm:inline"><%= day.strftime("%a") %></span>
          <span class="sm:hidden"><%= day.strftime("%a")[0] %></span>
          <span class="text-xs"><%= day.day %></span>
        </span>
      <% elsif day == @date %>
        <%= link_to journal_path(day), class: "btn btn-primary btn-sm sm:btn-md" do %>
          <span class="hidden sm:inline"><%= day.strftime("%a") %></span>
          <span class="sm:hidden"><%= day.strftime("%a")[0] %></span>
          <span class="text-xs"><%= day.day %></span>
        <% end %>
      <% elsif @days_with_content.include?(day) %>
        <%= link_to journal_path(day), class: "btn btn-ghost btn-sm" do %>
          <span class="hidden sm:inline"><%= day.strftime("%a") %></span>
          <span class="sm:hidden"><%= day.strftime("%a")[0] %></span>
          <span class="text-xs"><%= day.day %></span>
        <% end %>
      <% else %>
        <span class="btn btn-ghost btn-sm btn-disabled opacity-30">
          <span class="hidden sm:inline"><%= day.strftime("%a") %></span>
          <span class="sm:hidden"><%= day.strftime("%a")[0] %></span>
          <span class="text-xs"><%= day.day %></span>
        </span>
      <% end %>
    <% end %>
  </div>

  <% if next_week <= Date.current %>
    <%= link_to journal_path(next_week), class: "btn btn-ghost btn-sm" do %>
      &rarr;
    <% end %>
  <% else %>
    <span class="btn btn-ghost btn-sm btn-disabled">&rarr;</span>
  <% end %>

  <input type="date"
         class="input input-sm input-bordered w-36 hidden sm:inline-block"
         data-action="change->week-nav#jumpToDate"
         data-week-nav-target="datePicker"
         min="<%= current_user.created_at.to_date %>"
         max="<%= Date.current %>"
         value="<%= @date %>"
  >
</nav>
