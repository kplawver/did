<%= turbo_frame_tag dom_id(todo_item) do %>
  <div class="flex items-center gap-2 p-2 hover:bg-base-200 rounded-lg group">
    <%= form_with model: todo_item, method: :patch, data: { controller: "todo-toggle", action: "change->todo-toggle#submit" } do |f| %>
      <%= f.check_box :completed, class: "checkbox checkbox-sm", checked: todo_item.completed, data: { todo_toggle_target: "checkbox" } %>
    <% end %>

    <span class="flex-1 <%= 'line-through opacity-50' if todo_item.completed %>">
      <%= todo_item.title %>
    </span>

    <div class="opacity-0 group-hover:opacity-100"
         data-controller="due-date-picker"
         data-due-date-picker-due-date-value="<%= todo_item.due_date %>"
         data-action="mouseenter->due-date-picker#show mouseleave->due-date-picker#scheduleHide">
      <%= form_with model: todo_item, method: :patch, data: { due_date_picker_target: "form" } do |f| %>
        <%= f.hidden_field :due_date, data: { due_date_picker_target: "dateInput" } %>
      <% end %>

      <button type="button" class="btn btn-ghost btn-xs font-normal" data-due-date-picker-target="trigger">
        <%= todo_item.due_date == Date.current ? "Today" : todo_item.due_date.strftime("%b %-d") %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </button>

      <div class="fixed z-50 hidden bg-base-100 shadow-lg border border-base-300 rounded-xl p-3 w-60"
           data-due-date-picker-target="calendar"
           data-action="mouseenter->due-date-picker#cancelHide mouseleave->due-date-picker#scheduleHide">
        <div class="flex items-center justify-between mb-2">
          <button type="button" class="btn btn-ghost btn-xs" data-action="click->due-date-picker#prevMonth">&larr;</button>
          <span class="text-sm font-semibold" data-due-date-picker-target="monthLabel"></span>
          <button type="button" class="btn btn-ghost btn-xs" data-action="click->due-date-picker#nextMonth">&rarr;</button>
        </div>
        <div class="grid grid-cols-7 gap-y-1" data-due-date-picker-target="grid"></div>
      </div>
    </div>

    <%= button_to todo_item_path(todo_item), method: :delete, class: "btn btn-ghost btn-xs opacity-0 group-hover:opacity-100", data: { turbo_confirm: "Delete this todo?" } do %>
      &times;
    <% end %>
  </div>
<% end %>
