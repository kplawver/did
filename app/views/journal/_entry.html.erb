<%= turbo_frame_tag dom_id(entry) do %>
  <div class="card border-l-4 p-3 mb-2 <%= entry_color_classes(entry.tag) %> group">
    <div class="flex items-start justify-between">
      <div class="flex-1">
        <span class="badge badge-sm <%= entry_badge_class(entry.tag) %>"><%= entry.tag %></span>
        <span class="text-xs text-base-content/50 ml-2"><%= entry.created_at.strftime("%-I:%M %p") %></span>
      </div>
      <%= button_to entry_path(entry), method: :delete, class: "btn btn-ghost btn-xs opacity-0 group-hover:opacity-100", data: { turbo_confirm: "Delete this entry?" } do %>
        &times;
      <% end %>
    </div>
    <div class="prose prose-sm mt-1 max-w-none">
      <%= entry.body_html.html_safe %>
    </div>
  </div>
<% end %>
