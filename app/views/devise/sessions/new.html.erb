<div class="flex min-h-screen items-center justify-center bg-base-200">
  <div class="card w-full max-w-md bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title text-2xl justify-center">Sign In</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), class: "space-y-4") do |f| %>
        <div class="form-control">
          <%= f.label :email, class: "label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered w-full" %>
        </div>

        <div class="form-control">
          <%= f.label :password, class: "label" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "input input-bordered w-full" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="form-control">
            <label class="label cursor-pointer justify-start gap-2">
              <%= f.check_box :remember_me, class: "checkbox checkbox-primary" %>
              <span class="label-text">Remember me</span>
            </label>
          </div>
        <% end %>

        <div class="form-control mt-6">
          <%= f.submit "Sign In", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <div class="divider">OR</div>

      <div id="passkey-authentication" data-controller="passkey" data-passkey-challenge-url-value="<%= challenge_users_passkey_authentication_path %>">
        <button class="btn btn-outline w-full" data-action="passkey#authenticate">
          Sign in with Passkey
        </button>
      </div>

      <div class="text-center text-sm mt-4">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
